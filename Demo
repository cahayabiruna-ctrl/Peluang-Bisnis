  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap');
  body { font-family: 'Inter', sans-serif; margin:0; padding:0; background: #f0f9ff; overflow: hidden; }
  .presentation-container { position: relative; width: 100vw; height: 100vh; overflow: hidden; }
  .slide { 
    display: none; 
    position: absolute; 
    top: 0; 
    left: 0; 
    width: 100%; 
    height: 100%; 
    padding: 2rem 1rem; 
    text-align: center; 
    transition: all 0.7s ease-in-out; 
    transform: translateX(100%);
  }
  .active { 
    display: flex; 
    flex-direction: column; 
    justify-content: center; 
    align-items: center; 
    transform: translateX(0);
  }
  .slide-content { max-width: 800px; padding: 2rem; border-radius: 1rem; backdrop-filter: blur(5px); }
  .slide h1 { font-size: 2.5rem; font-weight: 700; margin-top: 1rem; color:#1a202c; opacity:0; transform: translateY(20px); animation: fadeSlideIn 1s forwards; }
  .slide p { font-size: 1.2rem; margin-top: 0.5rem; color:#4a5568; opacity:0; transform: translateY(20px); animation: fadeSlideIn 1s forwards; animation-delay:0.3s; }
  .lottie-slide { 
    width: 100%; 
    max-width: 350px; 
    height: 350px; 
    margin: auto; 
    opacity:0; 
    transform: scale(0.8); 
    animation: zoomBounce 1s forwards; 
    animation-delay: 0.5s; 
  }
  .nav-buttons { 
    position: fixed; 
    bottom: 2rem; 
    left: 50%; 
    transform: translateX(-50%); 
    display:flex; 
    gap: 1.5rem; 
    z-index: 20; 
  }
  .nav-buttons button { 
    padding: 12px 24px; 
    border: none; 
    border-radius: 9999px; 
    font-weight: 600; 
    cursor: pointer; 
    transition: all 0.3s ease; 
    background: #06b6d4; 
    color: white; 
    box-shadow: 0 4px 6px rgba(0,0,0,0.1); 
  }
  .nav-buttons button:hover { transform: translateY(-3px) scale(1.05); background: #0891b2; box-shadow: 0 6px 8px rgba(0,0,0,0.15); }
  
  @keyframes fadeSlideIn {
    to { opacity:1; transform: translateY(0); }
  }
  @keyframes zoomBounce {
    0% { transform: scale(0.8); opacity:0; }
    60% { transform: scale(1.05); opacity:1; }
    100% { transform: scale(1); }
  }
</style>
